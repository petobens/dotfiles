#cloud-config
---
users:
  - name: arch
    groups: [wheel, video, render, input]
    # Fish is installed later by the repository package profile
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
chpasswd:
  expire: false
  users:
    - {name: arch, password: wayland, type: text}
ssh_pwauth: true
mounts:
  - [
    dotfiles,
    /mnt/dotfiles,
    9p,
    "trans=virtio,version=9p2000.L,ro,nofail",
    "0",
    "0",
  ]
runcmd:
  - [cp, -a, /mnt/dotfiles, /home/arch/dotfiles-wayland]
  - [chown, -R, arch:arch, /home/arch/dotfiles-wayland]
  - [
    sudo,
    -u,
    arch,
    /home/arch/dotfiles-wayland/setup/install.sh,
    --all,
    --vm,
    --non-interactive,
  ]
  # Use the read-only host checkout for live Hyprland changes
  - [
    sudo,
    -u,
    arch,
    ln,
    -sfn,
    /mnt/dotfiles/hypr,
    /home/arch/.config/hypr,
  ]
  # Remove package archives after provisioning the disposable guest
  - [pacman, -Scc, --noconfirm]
  - [systemctl, enable, --now, qemu-guest-agent]
  - [systemctl, enable, --now, sshd]
power_state:
  mode: reboot
  message: Rebooting after dotfiles provisioning
  timeout: 30
  condition: true
