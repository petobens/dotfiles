#cloud-config
---
users:
  - name: pedro
    groups: [wheel, video, render, input]
    # Fish is installed later by the repository package profile
    shell: /bin/bash
    sudo: ALL=(ALL:ALL) ALL
    lock_passwd: false
chpasswd:
  expire: false
  users:
    - {name: pedro, password: wayland, type: text}
ssh_pwauth: true
mounts:
  - [
    dotfiles,
    /mnt/dotfiles,
    9p,
    "trans=virtio,version=9p2000.L,ro,nofail",
    "0",
    "0",
  ]
runcmd:
  - [install, -d, -o, pedro, -g, pedro, /home/pedro/git-repos/private]
  - [
    ln,
    -s,
    /mnt/dotfiles,
    /home/pedro/git-repos/private/dotfiles,
  ]
  - [
    chown,
    -h,
    pedro:pedro,
    /home/pedro/git-repos/private/dotfiles,
  ]
