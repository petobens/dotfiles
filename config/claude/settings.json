{
    "theme": "dark",
    "autoUpdates": false,
    "model": "opus[1m]",
    "effortLevel": "medium",
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Bash(stylua *)",
            "Read(/home/pedro/git-repos/**)"
        ],
        "deny": [
            "Bash(git push --force*)",
            "Bash(git push -f *)",
            "Bash(git reset --hard*)",
            "Bash(rm -rf *)",
            "Bash(sudo *)"
        ]
    }
}
